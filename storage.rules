rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == 'chamadossicofe@gmail.com';
    }

    function userPath() {
      return /databases/(default)/documents/usuarios/$(request.auth.uid);
    }

    function hasProfile() {
      return signedIn() && firestore.exists(userPath());
    }

    function myProfile() {
      return firestore.get(userPath()).data;
    }

    function isActive() {
      return signedIn()
        && (
          isBootstrapAdmin()
          || (hasProfile() && myProfile().ativo == true)
        );
    }

    function isAdmin() {
      return isActive()
        && (
          isBootstrapAdmin()
          || (hasProfile() && myProfile().papel == 'admin')
        );
    }

    function isOperator() {
      return isActive() && hasProfile() && myProfile().papel == 'operador';
    }

    function ticketPath(chamadoId) {
      return /databases/(default)/documents/chamados/$(chamadoId);
    }

    function ticketExists(chamadoId) {
      return firestore.exists(ticketPath(chamadoId));
    }

    function ticketData(chamadoId) {
      return firestore.get(ticketPath(chamadoId)).data;
    }

    function sameOrgTicket(chamadoId) {
      return hasProfile() && myProfile().organizacaoId == ticketData(chamadoId).organizacaoId;
    }

    function operatorCanAccessTicket(chamadoId) {
      return isOperator()
        && (
          ticketData(chamadoId).status != 'em_tratamento'
          || ticketData(chamadoId).operadorTratamentoId == request.auth.uid
        );
    }

    function canAccessTicket(chamadoId) {
      return isActive()
        && ticketExists(chamadoId)
        && (
          isAdmin()
          || sameOrgTicket(chamadoId)
          || operatorCanAccessTicket(chamadoId)
        );
    }

    match /chamados/{chamadoId}/{fileName=**} {
      allow read: if canAccessTicket(chamadoId);
      allow write: if canAccessTicket(chamadoId)
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
